generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Opportunity {
  id           String    @id @default(uuid())
  jobId        String
  source       String
  title        String
  company      String
  location     String?
  workingModel String?
  listingType  String?
  salaryMin    Int?
  salaryMax    Int?
  score        Int
  verdict      String?
  matchReasons String?
  redFlags     String?
  url          String?
  description  String?
  status       String    @default("new")
  appliedAt    DateTime?
  stage        String?
  createdAt    DateTime  @default(now())
  postedAt     DateTime?
  appliedVia           String?
  recruiterContact     String?
  fullJobSpecification String? @db.Text
  /** Set when an application leaves active apply flow: employer_rejected | user_archived | stale_auto */
  applicationClosedReason String? @map("application_closed_reason")

  contacts         ApplicationContact[]
  stageLogs        ApplicationStageLog[]
  scheduledEvents  ApplicationScheduledEvent[]
  correspondence   ApplicationCorrespondence[]

  @@unique([source, jobId])
  @@index([createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([status])
  @@index([stage])
  @@index([applicationClosedReason])
  @@map("opportunities")
}

model ApplicationContact {
  id            String   @id @default(uuid())
  opportunityId String
  name          String
  role          String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@index([opportunityId])
  @@map("application_contacts")
}

model ApplicationStageLog {
  id            String   @id @default(uuid())
  opportunityId String
  stage         String
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@index([opportunityId])
  @@map("application_stage_logs")
}

model ApplicationScheduledEvent {
  id            String   @id @default(uuid())
  opportunityId String
  kind          String
  scheduledAt   DateTime
  notes         String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([opportunityId])
  @@map("application_scheduled_events")
}

model ApplicationCorrespondence {
  id            String   @id @default(uuid())
  opportunityId String
  receivedAt    DateTime
  subject       String?
  body          String   @db.Text
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([receivedAt])
  @@map("application_correspondence")
}

model Rejection {
  id                     String   @id @default(uuid())
  jobId                  String
  source                 String
  title                  String
  company                String?
  url                    String
  score                  Int
  redFlags               String?
  createdAt              DateTime @default(now())
  /** When set, this row was created by ingest blocklist (server), not workflow disqualification. */
  ingestBlocklistRuleId  String?  @map("ingest_blocklist_rule_id")
  ingestBlocklistPattern String?  @map("ingest_blocklist_pattern")
  ingestBlocklistScope   String?  @map("ingest_blocklist_scope")

  @@index([createdAt(sort: Desc)])
  @@index([source])
  @@index([source, jobId])
  @@map("rejections")
}

/** Singleton (id = "default"): structured search criteria; systemPrompt cached from criteria on save. */
model SearchCriteriaSettings {
  id           String   @id @default("default")
  criteria     Json
  systemPrompt String   @db.Text
  updatedAt    DateTime @updatedAt

  @@map("search_criteria_settings")
}

model Feed {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("feeds")
}

enum IngestBlockScope {
  company
  title
  any
}

model IngestBlockRule {
  id        String           @id @default(uuid())
  createdAt DateTime         @default(now())
  enabled   Boolean          @default(true)
  pattern   String
  scope     IngestBlockScope
  note      String?

  @@index([enabled])
  @@map("ingest_block_rules")
}

/** Singleton (id = "default"): weekly/monthly meaningful-application targets for the dashboard. */
model ApplicationGoalSettings {
  id                  String @id @default("default")
  timezone            String @default("UTC")
  /** 0 = Sunday … 6 = Saturday (date-fns weekStartsOn). */
  weekStartsOn        Int    @default(1)
  weeklyTargetCount   Int    @default(0)
  monthlyTargetCount  Int    @default(0)

  @@map("application_goal_settings")
}

/** Singleton (id = "default"): stale threshold and future application workflow prefs. */
model ApplicationWorkflowSettings {
  id             String    @id @default("default")
  /** Days since apply with no future scheduled event → stale UI + auto-archive target. */
  staleIdleDays  Int       @default(40)
  /** Last time a throttled page-load auto-archive ran; optional cron also updates this. */
  lastAutoArchiveAt DateTime?

  @@map("application_workflow_settings")
}
