generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Opportunity {
  id           String    @id @default(uuid())
  jobId        String
  source       String
  title        String
  company      String
  location     String?
  workingModel String?
  listingType  String?
  salaryMin    Int?
  salaryMax    Int?
  score        Int
  verdict      String?
  matchReasons String?
  redFlags     String?
  url          String
  description  String?
  status       String    @default("new")
  appliedAt    DateTime?
  stage        String?
  createdAt    DateTime  @default(now())
  postedAt     DateTime?
  appliedVia           String?
  recruiterContact     String?
  fullJobSpecification String? @db.Text

  contacts        ApplicationContact[]
  stageLogs       ApplicationStageLog[]
  scheduledEvents ApplicationScheduledEvent[]

  @@unique([source, jobId])
  @@index([createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([status])
  @@index([stage])
  @@map("opportunities")
}

model ApplicationContact {
  id            String   @id @default(uuid())
  opportunityId String
  name          String
  role          String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@index([opportunityId])
  @@map("application_contacts")
}

model ApplicationStageLog {
  id            String   @id @default(uuid())
  opportunityId String
  stage         String
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@index([opportunityId])
  @@map("application_stage_logs")
}

model ApplicationScheduledEvent {
  id            String   @id @default(uuid())
  opportunityId String
  kind          String
  scheduledAt   DateTime
  notes         String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([opportunityId])
  @@map("application_scheduled_events")
}

model Rejection {
  id        String   @id @default(uuid())
  jobId     String
  source    String
  title     String
  company   String?
  url       String
  score     Int
  redFlags  String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([source])
  @@map("rejections")
}

model SystemPrompt {
  id                 String   @id @default(uuid())
  name               String
  systemPrompt       String
  userPromptTemplate String
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  notes              String?

  @@map("system_prompts")
}

model Feed {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("feeds")
}
